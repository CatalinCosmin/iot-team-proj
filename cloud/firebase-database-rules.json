{
  "rules": {
    "sensors": {
      "$deviceId": {
        "current": {
          ".read": true,
          ".write": true
        },
        "history": {
          ".read": true,
          ".write": true,
          ".indexOn": ["timestamp"]
        },
        ".read": true,
        ".write": true
      }
    }
  }
}
